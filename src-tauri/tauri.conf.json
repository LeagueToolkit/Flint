{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer-assets/installer-header.bmp",
        "sidebarImage": "installer-assets/installer-sidebar.bmp",
        "installMode": "currentUser",
        "languages": [
          "English"
        ],
        "displayLanguageSelector": false
      }
    },
    "createUpdaterArtifacts": "v1Compatible"
  },
  "productName": "Flint",
  "version": "1.8.9",
  "identifier": "com.sirdexal.flint",
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/LeagueToolkit/Flint/releases/latest/download/latest.json",
        "https://github.com/RitoShark/Flint/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGMUU1NjcwOEREQkNBRTgKUldUb3l0dU5jRlllNzZXL2RxK2orU1RzOXVZdnZ3YlF3cTBQczZaS0pMWlpGM0RNR2pING1Cd2UK"
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Flint",
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "script-src": "'self' blob: 'unsafe-eval'",
        "img-src": "'self' data: https: blob:",
        "connect-src": "'self' http://ipc.localhost https://raw.communitydragon.org https://github.com",
        "worker-src": "'self' blob:"
      },
      "dangerousDisableAssetCspModification": [
        "style-src",
        "script-src",
        "worker-src"
      ]
    }
  }
}
